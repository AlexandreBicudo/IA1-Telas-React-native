{
  "expo": {
    "name": "Atividade-Avaliativa-1",
    "slug": "Atividade-Avaliativa-1",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/chef_logo_new.png",
    "scheme": "seuchefe",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.seuchefegourmet.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A",
        "foregroundImage": "./assets/images/chef_logo_new.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "O SeuChefe precisa acessar sua galeria para você adicionar uma foto de perfil.",
          "cameraPermission": "O SeuChefe precisa acessar sua câmera para você tirar uma selfie de perfil."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cc135ef3-702a-4dbc-860d-162073288dd5"
      }
    }
  }
}
